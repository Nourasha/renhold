// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions             Session[]
  accounts             Account[]
  tasks                Task[]
  weekPlans            WeekPlan[]
  deviations           Deviation[]
  checklistCompletions ChecklistCompletion[]
  dailyNotes           DailyNote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model InviteCode {
  id        String    @id @default(cuid())
  // hashed with bcrypt — plain text is shown once at generation, never stored
  codeHash  String    @unique
  used      Boolean   @default(false)
  createdBy String
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  usedBy    String?
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeekPlan {
  id          String   @id @default(cuid())
  title       String
  description String?
  weekNumber  Int
  year        Int
  dayOfWeek   String
  startTime   String?
  endTime     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deviation {
  id          String   @id @default(cuid())
  title       String
  description String
  severity    String   @default("low")
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChecklistGroup {
  id    String          @id @default(cuid())
  title String
  order Int             @default(0)
  color String          @default("blue")
  items ChecklistItem[]
}

model ChecklistItem {
  id          String               @id @default(cuid())
  label       String
  order       Int                  @default(0)
  groupId     String
  group       ChecklistGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  completions ChecklistCompletion[]
}

model ChecklistCompletion {
  id          String        @id @default(cuid())
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime      @default(now())
  date        String        // "YYYY-MM-DD"
}

// One note per user per day
model DailyNote {
  id        String   @id @default(cuid())
  content   String
  date      String   // "YYYY-MM-DD"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
